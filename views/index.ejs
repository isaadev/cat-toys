<% layout('layouts/boilerplate')%>

    <div class="mt-5 mb-5 text-center" id="header">
        <h4><strong>Get your Cat Toys!</strong></h4>
        <p class="text-muted">Entertain your loved feline with some simple toys! </p>
    </div>
    <div class="jumbotron vertical-center">
        <div class="container text-center">
            <div class="row justify-content-center">
                <% for (let product of products) { %>
                <div class="col-md-4 col-md-offset-2 mb-4">
                    <a href="/<%= product._id %>">
                        <div class="card shadow" style="width: 70%;" id="floatthis">
                            <img src="<%= product.image %>" class="card-img-top" alt="<%=product.name%>">
                            <div class="card-body">
                                <h5 class="card-title">
                                    <%= product.name %>
                                </h5>
                                <p class="card-text mb-3">
                                    <%= product.description %>
                                </p>
                                <h5 id="price">$<%= product.price %></h5>
                            </div>
                        </div>
                    </a>
                </div>
                <% } %>
            </div>

        <footer class="mt-auto text-muted">
            <p>&copy; <%= new Date().getFullYear() %></p>
        </footer>
