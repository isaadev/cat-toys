<% layout('layouts/boilerplate')%>

<div class="hero-section">
    <div class="hero-content">
        <p class="hero-eyebrow">Free shipping on orders over $25</p>
        <h1>Toys Your Cat Will Actually Love</h1>
        <p class="hero-sub">Handpicked for curious minds and happy paws.</p>
        <a href="#products" class="btn btn-lg hero-btn">Shop Now</a>
    </div>
</div>

<div class="container" id="products">
    <div class="section-header text-center mb-5">
        <h4>Our Products</h4>
        <p class="text-muted">Everything your feline needs to stay entertained</p>
    </div>
    <div class="row justify-content-center">
        <% for (let product of products) { %>
        <div class="col-md-4 mb-5">
            <a href="/<%= product._id %>" class="product-link">
                <div class="card shadow-sm product-card">
                    <div class="product-img-wrap">
                        <img src="<%= product.image %>" class="card-img-top" alt="<%=product.name%>">
                    </div>
                    <div class="card-body">
                        <h5 class="card-title"><%= product.name %></h5>
                        <p class="card-text mb-3"><%= product.description %></p>
                        <div class="d-flex justify-content-between align-items-center">
                            <h5 id="price" class="mb-0">$<%= product.price %></h5>
                            <span class="view-link">View &rarr;</span>
                        </div>
                    </div>
                </div>
            </a>
        </div>
        <% } %>
    </div>
</div>

<footer class="site-footer mt-5">
    <p>&copy; <%= new Date().getFullYear() %> MeowPlay &bull; Made with ♥ for cats</p>
</footer>
